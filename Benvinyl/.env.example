APP_ENV=development
HOST=0.0.0.0
PORT=9400

SECRET_KEY=change-this-session-secret
SSO_SECRET=change-this-shared-sso-secret
REMEMBER_DAYS=30
SESSION_COOKIE_NAME=benvinyl_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false

ADMIN_USERNAME=benbenbuben
ADMIN_PASSWORD=benbenbuben
BENBOT_BASE_URL=http://localhost:80

DATABASE_URL=sqlite:////Users/ben/Desktop/myapp/Ben_cloud/Benvinyl/data/benvinyl.sqlite
DAILY_RECORD_COUNT=4
TRASH_PREVIEW_LIMIT=18

# 留空时只能手工录入完整公网 URL；若要启用启动/读路径自动补库，请同时配置 endpoint/access key/bucket/prefix。
ALIYUN_OSS_PUBLIC_BASE_URL=
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=replace_with_oss_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=replace_with_oss_access_key_secret
ALIYUN_OSS_BUCKET=your-bucket
ALIYUN_OSS_PREFIX=benvinyl
ALIYUN_OSS_ALLOWED_EXTENSIONS=.mp3,.m4a,.aac,.wav,.flac,.ogg
