# Bensci .env example
# Copy: cp .env.example .env

# Runtime server (used by bensci.sh)
HOST=0.0.0.0
PORT=8300
WORKERS=4

# Service
APP_NAME=CATAPEDIA Metadata Service
APP_VERSION=0.1.0
API_PREFIX=/api

# Storage / SQLite
BASE_DIR=data
SQLITE_FILENAME=metadata.db
SQLITE_JOURNAL_MODE=WAL
SQLITE_BUSY_TIMEOUT_SECONDS=30.0
SQLITE_SYNCHRONOUS=NORMAL
EXPORT_DIR=data/exports

# Request / worker
REQUEST_TIMEOUT_SECONDS=60
REQUEST_USER_AGENT=catapedia-metadata/0.1
PROVIDER_SLEEP_SECONDS=0.2
ENRICHMENT_WORKERS=4
TASK_WORKER_CONCURRENCY=2
TASK_POLL_INTERVAL_SECONDS=0.5

# Auto enrichment
AUTO_ENRICHMENT_ENABLED=true
AUTO_ENRICHMENT_INTERVAL_SECONDS=180
AUTO_ENRICHMENT_LIMIT=100
AUTO_ENRICHMENT_WORKERS=4

# AI
ALIYUN_AI_API_KEY=
ALIYUN_AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_AI_MODEL=qwen-plus
ALIYUN_AI_EMBEDDING_MODEL=text-embedding-v4
ALIYUN_AI_EMBEDDING_DIMENSIONS=1024
QUERY_FILTER_LLM_FALLBACK_MODELS=qwen-turbo

# Optional defaults
DEFAULT_PROVIDERS=crossref,openalex,pubmed,springer,elsevier,arxiv
# JOURNAL_METRICS_CSV_PATH=data/journal_impact_factors.csv

# Provider keys
SPRINGER_META_API_KEY=
SPRINGER_META_API_BASE=https://api.springernature.com/meta/v2/json
ELSEVIER_API_KEY=

# Security / CORS
SSO_SECRET=replace_with_shared_sso_secret
CORS_ORIGINS=*
