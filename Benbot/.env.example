# Benbot .env example
# Copy: cp .env.example .env

# App
APP_ENV=development
HOST=0.0.0.0
PORT=80
API_PREFIX=/api

# Security (required)
SECRET_KEY=replace_with_long_random_session_secret
SSO_SECRET=replace_with_shared_sso_secret
NANOBOT_API_TOKEN=replace_with_long_random_api_token

# Admin bootstrap
ADMIN_USERNAME=benbenbuben
ADMIN_PASSWORD=benbenbuben

# Nanobot API authz
NANOBOT_API_SCOPES=bug_repair:read,bug_repair:write
NANOBOT_API_ALLOWED_IPS=127.0.0.1,::1

# Session
REMEMBER_DAYS=30
SESSION_COOKIE_NAME=benbot_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false

# Database (optional; default is sqlite data/benbot.sqlite)
DATABASE_URL=sqlite:////Users/ben/Desktop/Ben_cloud/Benbot/data/benbot.sqlite

# Health check
HEALTH_CHECK_INTERVAL=60
HEALTH_CHECK_SINGLE_LEADER=true
ENABLE_PROMETHEUS_METRICS=true

# Registry
PROJECT_REGISTRY_FILE=/Users/ben/Desktop/Ben_cloud/PROJECT_STANDARDS/registry.yaml
PROJECT_REGISTRY_STRICT=false

# Runtime hardening
SECURITY_STRICT_MODE=false

# Sub-project URLs (health uses INTERNAL, browser redirect uses PUBLIC)
BENOSS_INTERNAL_URL=http://localhost:8000
BENOSS_PUBLIC_URL=http://localhost:8000
BENLAB_INTERNAL_URL=http://localhost:9000
BENLAB_PUBLIC_URL=http://localhost:9000
BENUSY_INTERNAL_URL=http://localhost:8100
BENUSY_PUBLIC_URL=http://localhost:8100
BENOME_INTERNAL_URL=http://localhost:8200
BENOME_PUBLIC_URL=http://localhost:8200
BENSCI_INTERNAL_URL=http://localhost:8300
BENSCI_PUBLIC_URL=http://localhost:8300
BENFER_INTERNAL_URL=http://localhost:8500
BENFER_PUBLIC_URL=http://localhost:8500
BENBEN_INTERNAL_URL=http://localhost:8600
BENBEN_PUBLIC_URL=http://localhost:8600
BENFAST_INTERNAL_URL=http://localhost:8700
BENFAST_PUBLIC_URL=http://localhost:8700
BENCRED_INTERNAL_URL=http://localhost:9600
BENCRED_PUBLIC_URL=http://localhost:9600
