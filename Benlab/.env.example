# Benlab .env example
# Copy: cp .env.example .env

# App
APP_NAME=Benlab
APP_ENV=development
API_PREFIX=/api
HOST=0.0.0.0
PORT=9000
SECRET_KEY=replace_with_long_random_session_secret

# Database
DATABASE_URL=sqlite:////Users/ben/Desktop/Ben_cloud/Benlab/data/benlab.sqlite
DB_BOOTSTRAP_CREATE_ALL=false

# Admin / session
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_admin_password
REMEMBER_DAYS=30
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false

# Paths
ATTACHMENTS_DIR=/Users/ben/Desktop/Ben_cloud/Benlab/data/uploads
LOGS_DIR=/Users/ben/Desktop/Ben_cloud/Benlab/logs

# Share links
EVENT_SHARE_TOKEN_SALT=benlab-event-share
EVENT_SHARE_TOKEN_MAX_AGE=2592000

# Upload strategy
DIRECT_OSS_UPLOAD_ENABLED=false

# SSO (read by /auth/sso route; should match Benbot)
SSO_SECRET=replace_with_shared_sso_secret

# Runtime settings (optional)
BOARD_DEFAULT_DAYS=7
BOARD_TOP_TAGS_DAYS=30
BOARD_TOP_TAGS_LIMIT=10
DIGEST_TIMEZONE=Asia/Shanghai
VECTOR_TOP_K=8
VECTOR_MAX_DOCS=4000

# Optional: use custom runtime settings json file
# BENLAB_ADMIN_SETTINGS_FILE=/absolute/path/to/admin_settings.json
