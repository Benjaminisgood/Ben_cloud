# Benben .env example
# Copy: cp .env.example .env

# App
BENBEN_APP_NAME=Benben
BENBEN_APP_ENV=development
BENBEN_HOST=0.0.0.0
BENBEN_PORT=8600
BENBEN_DEFAULT_PROJECT=Lab Shared Project

# OSS (required)
BENBEN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
BENBEN_OSS_ACCESS_KEY_ID=replace_with_your_aliyun_access_key_id
BENBEN_OSS_ACCESS_KEY_SECRET=replace_with_your_aliyun_access_key_secret
BENBEN_OSS_BUCKET_NAME=replace_with_your_oss_bucket_name
BENBEN_OSS_PREFIX=benben

# SSO / Session (required)
# BENBEN_SSO_SECRET must match Benbot SSO_SECRET
BENBEN_SSO_SECRET=replace_with_shared_sso_secret
BENBEN_SESSION_SECRET_KEY=replace_with_32_plus_char_random_secret
BENBEN_SESSION_MAX_AGE_SECONDS=43200
BENBEN_SESSION_COOKIE_SECURE=false

# Upload / markdown guardrails
BENBEN_UPLOAD_MAX_BYTES=5242880
BENBEN_UPLOAD_MAX_REQUESTS_PER_MINUTE=20
BENBEN_MARKDOWN_MAX_BYTES=1048576

# Audit
BENBEN_AUDIT_LOG_PATH=logs/benben_audit.log
BENBEN_AUDIT_MAX_BYTES=5242880
