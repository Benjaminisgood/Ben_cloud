# Benoss .env example
# Copy: cp .env.example .env

# App
APP_ENV=development
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api

# Core / auth
SECRET_KEY=replace_with_long_random_session_secret
SSO_SECRET=replace_with_shared_sso_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_admin_password
DATABASE_URL=sqlite:////Users/ben/Desktop/Ben_cloud/Benoss/data/benoss.sqlite
DB_BOOTSTRAP_CREATE_ALL=false
DB_AUTO_UPGRADE_ON_STARTUP=true

# Session
REMEMBER_DAYS=30
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false

# OSS
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=replace_with_your_aliyun_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=replace_with_your_aliyun_access_key_secret
ALIYUN_OSS_BUCKET=replace_with_your_oss_bucket
ALIYUN_OSS_PREFIX=benoss
ALIYUN_OSS_PUBLIC_BASE_URL=
ALIYUN_OSS_ASSUME_PUBLIC=0
OSS_DIRECT_UPLOAD_ENABLED=1
OSS_DIRECT_UPLOAD_EXPIRES_SECONDS=900
OSS_DIRECT_UPLOAD_TOKEN_MAX_AGE_SECONDS=1800
OSS_REMOTE_FAILOVER_LOCAL=1

# Limits / board
MAX_CONTENT_LENGTH=1073741824
BOARD_DEFAULT_DAYS=7
BOARD_TOP_TAGS_DAYS=0
BOARD_TOP_TAGS_LIMIT=10

# AI routing
AI_CHAT_PROVIDER=aliyun
AI_EMBEDDING_PROVIDER=aliyun
AI_TTS_PROVIDER=aliyun
AI_IMAGE_PROVIDER=aliyun
AI_REQUEST_TIMEOUT_SECONDS=45
AI_MAX_NOTICE_RECORDS=180
AI_NOTICE_CONTEXT_MAX_CHARS=60000
AI_NOTICE_RECORD_MAX_CHARS=3200
AI_NOTICE_FILE_READ_MAX_BYTES=524288
AI_NOTICE_ATTACH_IMAGES=1
AI_NOTICE_MAX_IMAGE_ATTACHMENTS=6
AI_NOTICE_IMAGE_URL_EXPIRES_SECONDS=1800
AI_ARCHIVE_MULTIMODAL_PARSE=1
AI_ARCHIVE_PARSE_MAX_CHARS=8000
AI_ARCHIVE_PARSE_TIMEOUT_SECONDS=90
AI_TTS_VOICE=alloy
AI_TTS_RESPONSE_FORMAT=mp3
AI_TTS_MAX_INPUT_CHARS=3600
AI_TTS_FALLBACK_LOCAL=1
AI_IMAGE_FALLBACK_LOCAL=1
PODCAST_DEFAULT_STYLE=dialogue

# Archive / vector
LOCAL_DAILY_ARCHIVE_DIR=/Users/ben/Desktop/Ben_cloud/Benoss/data/daily-archive
LOCAL_VECTOR_STORE_DIR=/Users/ben/Desktop/Ben_cloud/Benoss/data/vector-store
VECTOR_AUTO_REBUILD=1
VECTOR_TOP_K=6
VECTOR_MAX_DOCS=4000
VECTOR_EMBEDDING_BATCH_SIZE=16
VECTOR_EMBEDDING_MAX_INPUT_CHARS=4000
HOME_AUTO_BUILD_DAILY_ASSETS=1
HOME_DIGEST_RETRY_MINUTES=30
DIGEST_TIMEZONE=Asia/Shanghai
ARCHIVE_RETENTION_DAYS=7
ARCHIVE_STORE_FILE_BLOB=1

# ChatAnywhere provider
CHAT_ANYWHERE_API_KEY=
CHAT_ANYWHERE_API_BASE_URL=https://api.chatanywhere.tech/v1
CHAT_ANYWHERE_CHAT_MODEL=gpt-4o-mini
CHAT_ANYWHERE_EMBEDDING_MODEL=text-embedding-3-small
CHAT_ANYWHERE_TTS_MODEL=gpt-4o-mini-tts
CHAT_ANYWHERE_IMAGE_MODEL=gpt-image-1
CHAT_ANYWHERE_TRANSCRIBE_MODEL=whisper-1

# DeepSeek provider
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=unsupported
DEEPSEEK_TTS_MODEL=unsupported
DEEPSEEK_IMAGE_MODEL=unsupported
DEEPSEEK_TRANSCRIBE_MODEL=unsupported

# Aliyun AI provider
ALIYUN_AI_API_KEY=
ALIYUN_AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_AI_CHAT_MODEL=qwen-plus
ALIYUN_AI_EMBEDDING_MODEL=text-embedding-v3
ALIYUN_AI_TTS_MODEL=qwen3-tts-instruct-flash
ALIYUN_AI_IMAGE_MODEL=qwen-image-max
ALIYUN_AI_TRANSCRIBE_MODEL=whisper-1

# OpenAI provider
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TRANSCRIBE_MODEL=whisper-1
