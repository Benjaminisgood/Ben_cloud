{
  "format": "nanobot-http-action-map.v1",
  "service": {
    "name": "benoss",
    "base_url": "http://127.0.0.1:8000",
    "openapi": "automation/openapi.json",
    "index": "automation/api_index.json"
  },
  "auth": {
    "mode": "session_cookie",
    "cookie_name": "session",
    "login_action": "auth_login",
    "logout_action": "auth_logout",
    "reauth_on_status": [401],
    "defaults": {
      "next": "/"
    }
  },
  "variables": {
    "username": "Benoss username",
    "password": "Benoss password",
    "text": "post text content",
    "visibility": "public|private",
    "tags": "array of tags",
    "record_id": "target record id",
    "comment_body": "comment text",
    "limit": "pagination limit",
    "before_id": "pagination cursor"
  },
  "actions": [
    {
      "id": "auth_login",
      "description": "Login and establish session cookie.",
      "request": {
        "method": "POST",
        "path": "/login",
        "content_type": "application/x-www-form-urlencoded",
        "body_form": {
          "username": "{{username}}",
          "password": "{{password}}",
          "next": "{{next|default:/}}"
        }
      },
      "expect": {
        "status_any_of": [302]
      }
    },
    {
      "id": "auth_logout",
      "description": "Logout current session.",
      "request": {
        "method": "GET",
        "path": "/logout"
      },
      "expect": {
        "status_any_of": [302]
      }
    },
    {
      "id": "health_check",
      "description": "Check API liveness.",
      "request": {
        "method": "GET",
        "path": "/health"
      },
      "expect": {
        "status_any_of": [200]
      }
    },
    {
      "id": "account_me",
      "description": "Get current account and user list.",
      "request": {
        "method": "GET",
        "path": "/api/account"
      },
      "expect": {
        "status_any_of": [200]
      }
    },
    {
      "id": "create_post_text",
      "description": "Create a text record (post).",
      "request": {
        "method": "POST",
        "path": "/api/records",
        "content_type": "application/json",
        "body_json": {
          "text": "{{text}}",
          "visibility": "{{visibility|default:private}}",
          "tags": "{{tags|default:[\"nanobot\"]}}"
        }
      },
      "expect": {
        "status_any_of": [201]
      }
    },
    {
      "id": "list_posts",
      "description": "List records with cursor pagination.",
      "request": {
        "method": "GET",
        "path": "/api/records",
        "query": {
          "limit": "{{limit|default:20}}",
          "before_id": "{{before_id|optional}}"
        }
      },
      "expect": {
        "status_any_of": [200]
      }
    },
    {
      "id": "get_post",
      "description": "Get a single record by id.",
      "request": {
        "method": "GET",
        "path": "/api/records/{{record_id}}"
      },
      "expect": {
        "status_any_of": [200]
      }
    },
    {
      "id": "update_post",
      "description": "Patch record fields.",
      "request": {
        "method": "PATCH",
        "path": "/api/records/{{record_id}}",
        "content_type": "application/json",
        "body_json": {
          "text": "{{text|optional}}",
          "visibility": "{{visibility|optional}}",
          "tags": "{{tags|optional}}"
        }
      },
      "expect": {
        "status_any_of": [200]
      }
    },
    {
      "id": "delete_post",
      "description": "Delete record by id.",
      "request": {
        "method": "DELETE",
        "path": "/api/records/{{record_id}}"
      },
      "expect": {
        "status_any_of": [204]
      }
    },
    {
      "id": "create_comment",
      "description": "Create comment under record.",
      "request": {
        "method": "POST",
        "path": "/api/records/{{record_id}}/comments",
        "content_type": "application/json",
        "body_json": {
          "body": "{{comment_body}}"
        }
      },
      "expect": {
        "status_any_of": [201]
      }
    },
    {
      "id": "list_comments",
      "description": "List comments of record.",
      "request": {
        "method": "GET",
        "path": "/api/records/{{record_id}}/comments"
      },
      "expect": {
        "status_any_of": [200]
      }
    },
    {
      "id": "list_tags",
      "description": "Query tag suggestions.",
      "request": {
        "method": "GET",
        "path": "/api/tags",
        "query": {
          "q": "{{q|optional}}",
          "limit": "{{limit|default:20}}"
        }
      },
      "expect": {
        "status_any_of": [200]
      }
    },
    {
      "id": "home_today",
      "description": "Read home dashboard API payload.",
      "request": {
        "method": "GET",
        "path": "/api/home/today"
      },
      "expect": {
        "status_any_of": [200]
      }
    }
  ],
  "recipes": [
    {
      "id": "publish_post_flow",
      "steps": [
        "health_check",
        "auth_login",
        "create_post_text",
        "list_posts"
      ]
    },
    {
      "id": "comment_flow",
      "steps": [
        "health_check",
        "auth_login",
        "create_comment",
        "list_comments"
      ]
    }
  ],
  "notes": [
    "If an action returns 401, call auth_login again and retry once.",
    "For list endpoints, iterate with before_id until has_more=false.",
    "Use private visibility unless explicit public publishing is intended."
  ]
}
