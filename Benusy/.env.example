# Benusy .env example
# Copy: cp .env.example .env

# App
APP_NAME=Influencer Promotion Platform
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8100

# Auth / database
SECRET_KEY=replace_with_long_random_session_secret
SSO_SECRET=replace_with_shared_sso_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REMEMBER_ME_ACCESS_TOKEN_EXPIRE_DAYS=30
DATABASE_URL=sqlite:////Users/ben/Desktop/Ben_cloud/Benusy/data/benusy.sqlite
DB_BOOTSTRAP_CREATE_ALL=false

# Session
REMEMBER_DAYS=30
SESSION_COOKIE_NAME=benusy_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false

# Runtime
METRICS_UPDATE_INTERVAL_SECONDS=1800
DEFAULT_USER_WEIGHT=0.001

# OSS (optional)
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_PREFIX=benusy
ALIYUN_OSS_PUBLIC_BASE_URL=
ALIYUN_OSS_TASK_ATTACHMENT_DIR=task-attachments
ALIYUN_OSS_PAYOUT_QR_DIR=payout-qrcodes

# Optional homepage overrides (defaults are in config.py)
# HOMEPAGE_NAV_BRAND=Influencer Platform
# HOMEPAGE_HERO_TITLE=Influencer Platform
# HOMEPAGE_HERO_SUBTITLE=Connect brands and creators efficiently.
# HOMEPAGE_HERO_IMAGE_URL=/static/images/hero-image.png
# HOMEPAGE_HERO_PRIMARY_BUTTON_TEXT=Sign Up
# HOMEPAGE_HERO_PRIMARY_BUTTON_HREF=/auth/register
# HOMEPAGE_HERO_SECONDARY_BUTTON_TEXT=Learn More
# HOMEPAGE_HERO_SECONDARY_BUTTON_HREF=#how-it-works
# HOMEPAGE_MERCHANT_CONTACT_PHONE=+86-000-0000-0000
# HOMEPAGE_MERCHANT_CONTACT_WECHAT=your_wechat_id
# HOMEPAGE_MERCHANT_CONTACT_EMAIL=merchant@example.com
# HOMEPAGE_CONTACT_ADDRESS=Your office address
# HOMEPAGE_CONTACT_PHONE=+86-000-0000-0000
# HOMEPAGE_CONTACT_EMAIL=info@example.com
