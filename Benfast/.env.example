# Python Path Configuration
PYTHONPATH=src

# 应用配置
VERSION=1.0.0
APP_TITLE=企业级FastAPI后端模板
PROJECT_NAME=YourProject
APP_DESCRIPTION="企业级FastAPI后端模板 - 开箱即用"
PORT=8700

# 安全配置 (必须修改)
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32
SWAGGER_UI_USERNAME=admin
SWAGGER_UI_PASSWORD=your_swagger_password_here
SSO_SECRET=replace_with_shared_sso_secret
SSO_REDIRECT_PATH=/
SSO_TOKEN_COOKIE_NAME=benfast_access_token
SSO_REFRESH_COOKIE_NAME=benfast_refresh_token
ADMIN_USERNAME=benbenbuben
ADMIN_PASSWORD=benbenbuben

# 应用配置
APP_ENV=development
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=240

# Database Configuration
DB_ENGINE=sqlite
SQLITE_DB_PATH=data/benfast.sqlite3
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_database_password_here
DB_NAME=your_database_name

# CORS配置 - 根据实际情况修改
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# 文档工作台与发布站
DOCS_SITE_DIR=site
LABDOCS_STORAGE_BACKEND=local
LABDOCS_STORAGE_PREFIX=benfast
LABDOCS_LOCAL_ROOT=data/labbooks
LABDOCS_DOCS_SOURCE_ROOT=data/docs_site_source
LABDOCS_PUBLISH_ROOT=site/books

# 阿里云 OSS（当 LABDOCS_STORAGE_BACKEND=aliyun_oss 时启用）
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=replace_me
ALIYUN_OSS_ACCESS_KEY_SECRET=replace_me
ALIYUN_OSS_BUCKET=replace_me

# 调试模式 (生产环境设置为False)
DEBUG=True
