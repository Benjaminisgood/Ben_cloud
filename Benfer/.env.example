# Benfer .env example
# Copy: cp .env.example .env

# Server
HOST=0.0.0.0
PORT=8500

# Database
DATABASE_URL=sqlite:///./data/benfer.db

# OSS
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=replace_with_your_aliyun_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=replace_with_your_aliyun_access_key_secret
ALIYUN_OSS_BUCKET=replace_with_your_oss_bucket
ALIYUN_OSS_PREFIX=benfer

# SSO (must match Benbot)
SSO_SECRET=replace_with_shared_sso_secret

# Nanobot API token
NANOBOT_API_TOKEN=replace_with_random_api_token

# Clipboard / files
CLIPBOARD_STORAGE_PATH=./data/clipboard
FILE_EXPIRATION_HOURS=24
SESSION_TOKEN_TTL_SECONDS=43200
PRESIGNED_URL_EXPIRES_SECONDS=3600
MAX_FILE_SIZE_BYTES=5368709120
MAX_CLIPBOARD_CHARS=200000
ALLOWED_FILE_CONTENT_TYPES=text/plain,text/csv,application/json,application/pdf,application/zip,application/octet-stream,image/*,video/*

# CORS / host hardening
CORS_ALLOWED_ORIGINS=http://localhost:8500,http://127.0.0.1:8500
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,00ling.com,testserver
